{
  "name": "bom-manager",
  "version": "2.5.0",
  "description": "BOM Yönetim Sistemi - Jira Uyumlu, Excel Import, Görselleştirme (Offline)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.bom-manager.app",
    "productName": "BOM Manager",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^24.9.1"
  }
}